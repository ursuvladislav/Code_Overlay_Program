<UserControl x:Class="CodeOverlayRunner.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20"
                                HorizontalAlignment="Center">
                        
                        <TextBlock Text="Settings"
                                FontSize="22"
                                FontWeight="Bold"
                                HorizontalAlignment="Left"
                                Width="220"
                                Margin="0,0,0,20"/>

                        <!-- Interface Language -->
                        <TextBlock Text="Interface Language"
                                FontWeight="SemiBold"
                                Width="220"
                                Margin="0,0,0,4"/>
                        
                        <ComboBox x:Name="InterfaceLanguageComboBox"
                                Width="220"
                                Height="24"
                                Margin="0,0,0,10"
                                SelectedIndex="0">

                                <ComboBoxItem Content="English"/>
                                <ComboBoxItem Content="Русский"/>
                                <ComboBoxItem Content="Română"/>
                        </ComboBox>

                        <!-- Programming Language -->
                        <TextBlock Text="Programming Language"
                                FontWeight="SemiBold"
                                Width="220"
                                Margin="0,0,0,4"/>

                        <ComboBox x:Name="ProgrammingLanguageComboBox"
                                Width="220"
                                Height="24"
                                Margin="0,0,0,10"
                                SelectedIndex="1">

                                <ComboBoxItem Content="Auto"/>
                                <ComboBoxItem Content="C++"/>
                                <ComboBoxItem Content="Python (coming soon)" IsEnabled="False"/>
                                <ComboBoxItem Content="C# (coming soon)" IsEnabled="False"/>
                                <ComboBoxItem Content="JavaScript (coming soon)" IsEnabled="False"/>
                        </ComboBox>

                        <!-- Timeout -->
                        <TextBlock Text="Execution Timeout"
                                FontWeight="SemiBold"
                                Width="220"
                                Margin="0,0,0,4"/>

                        <ComboBox x:Name="TimeoutComboBox"
                                Width="220"
                                Height="24"
                                Margin="0,0,0,10"
                                SelectedIndex="0">

                                <ComboBoxItem Content="2000 ms"/>
                                <ComboBoxItem Content="3000 ms"/>
                                <ComboBoxItem Content="5000 ms"/>
                        </ComboBox>

                        <!-- Hotkeys Info -->
                        <TextBlock Text="Hotkeys"
                                FontWeight="SemiBold"
                                Width="220"
                                Margin="0,0,0,4"/>

                        <TextBlock Text="Compile: Ctrl + Shift + Space&#x0a;Stop Overlay: Ctrl + Shift + Alt + O"
                                Width="220"
                                FontSize="12"
                                Margin="0,0,0,14"/>

                        <Grid Width="220">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Save"
                                Height="36"
                                Click="SaveButton_Click"/>

                        <Button Grid.Column="2"
                                Content="Back"
                                Height="36"
                                Click="BackButton_Click"/>
                        </Grid>
                </StackPanel>
        </ScrollViewer>
</UserControl>