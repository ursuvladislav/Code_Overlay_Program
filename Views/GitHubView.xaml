<UserControl x:Class="CodeOverlayRunner.Views.GitHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="20"
                HorizontalAlignment="Center">
        <TextBlock Text="GitHub"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <TextBlock Text="Open project repository on GitHub."
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="0,0,0,25"/>


        <Button Content="Open GitHub"
                Width="220"
                Height="40"
                Margin="0,0,0,10"
                Click="OpenGitHubButton_Click"/>

        <Button Content="Back"
                Width="220"
                Height="40"
                Click="BackButton_Click"/>

    </StackPanel>
</UserControl>